{
  "manifest_version": 3,
  "name": "Gluon v2",
  "version": "0.2.2",
  "description": "Gluon extension",
  
  "permissions": [
    "sidePanel",
    "storage",
    "declarativeNetRequest",
    "scripting",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://gemini.google.com/*",
    "https://aistudio.google.com/*",
    "https://claude.ai/*",
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://claude.ai/*"
      ],
      "js": [
        "src/content/detectors/gluon-command-detector.js",
        "src/content/detectors/response-detector.js",
        "src/content/detectors/apply-system-detector.js",
        "src/content/injectors/gemini-injector.js",
        "src/content/overlays/apply-system-overlay.js",
        "src/content/agent-pairing-overlay.js",
        "src/content/ai-studio-agent.js",
        "src/content/content.js"
      ],
      "css": ["src/content/content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  
  "web_accessible_resources": [
    {
      "resources": [
        "src/sidebar/sidebar.html",
        "src/content/ai-studio-network-interceptor.js",
        "assets/**"
      ],
      "matches": [
        "https://gemini.google.com/*",
        "https://aistudio.google.com/*",
        "https://claude.ai/*"
      ]
    }
  ],
  
  "icons": {
    "16": "assets/icons/icon16.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },

  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  
  "action": {
    "default_title": "Gluon POC",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "src/sidebar/sidebar.html"
  }
}